# NWO Market Layer 6 — Environment Variables

# ── NWO Cardiac SDK services ───────────────────────────────────────────────────
CARDIAC_ORACLE_URL=https://nwo-oracle.onrender.com
CARDIAC_RELAYER_URL=https://nwo-relayer.onrender.com
CARDIAC_ORACLE_SECRET=                        # X-Oracle-Secret header
CARDIAC_RELAYER_SECRET=                        # X-Relayer-Secret header

# ── Base Mainnet (Chain ID 8453) ──────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org          # Public RPC; use Alchemy/Infura in prod
BASE_CHAIN_ID=8453

# NWO Cardiac SDK contracts (deployed, do not redeploy)
NWO_IDENTITY_REGISTRY=0x78455AFd5E5088F8B5fecA0523291A75De1dAfF8
NWO_ACCESS_CONTROLLER=0x29d177bedaef29304eacdc63b2d0285c459a0f50
NWO_PAYMENT_PROCESSOR=0x4afa4618bb992a073dbcfbddd6d1aebc3d5abd7c

# Platform wallet (for issuing credentials — must hold ISSUER_ROLE on-chain)
# NEVER commit the private key. Use a secrets manager in production.
PLATFORM_WALLET_PRIVATE_KEY=
PLATFORM_WALLET_ADDRESS=

# ── nwo-simulation-api ─────────────────────────────────────────────────────────
SIMULATION_API_URL=https://github.com/RedCiprianPater/nwo-simulation-api
# If running locally:
# SIMULATION_API_URL=http://localhost:8090
SIMULATION_API_KEY=
SIMULATION_TIMEOUT_SEC=300
DEFAULT_SIMULATOR=mujoco                       # mujoco | gazebo

# ── Assembly AI (Claude API) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ASSEMBLY_AI_MODEL=claude-opus-4-5
ASSEMBLY_CACHE_TTL_HOURS=24                    # Cache generated instructions

# ── Token economy thresholds ──────────────────────────────────────────────────
SIMULATE_CREDIT_COST=5                         # Credits to run a simulation
SETTLEMENT_MIN_CREDITS=50                      # Min credits before on-chain settlement
SETTLEMENT_ETH_PER_CREDIT=0.0001              # Credit → ETH rate for settlement

# ── Database (cache layer) ─────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./market.db

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8006
LAYER5_GATEWAY_URL=http://localhost:8080

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
